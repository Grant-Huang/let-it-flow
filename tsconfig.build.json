{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "noEmitOnError": false,
    "composite": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "reference",
    "tests",
    "apps",
    "scripts",
    "web",
    "packages",
    "examples",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
