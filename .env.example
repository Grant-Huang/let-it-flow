# =============================================================================
# Let-it-Flow 环境变量示例
# 复制为 .env 并填入真实值。.env 已被 .gitignore 排除，勿提交。
# =============================================================================

# ── LLM 密钥（按需配置，对应 registry 的 apiKeyEnv 字段）─────────────────────
# OpenAI 官方 / OpenAI 兼容服务（DeepSeek、通义、Kimi 等）共用此 key
OPENAI_API_KEY=sk-...
# Anthropic Claude（provider=anthropic 时必填，apiKeyEnv=ANTHROPIC_API_KEY）
ANTHROPIC_API_KEY=sk-ant-...
# Azure OpenAI（provider=azure 时必填，apiKeyEnv=AZURE_API_KEY）
AZURE_API_KEY=...
# Ollama 本地无需 key（provider=ollama，baseURL 默认 http://localhost:11434/v1）

# ── OpenAI 兼容服务路由 ─────────────────────────────────────────────────────
# 留空走 OpenAI 官方端点；填 https://api.deepseek.com 等走兼容服务
OPENAI_BASE_URL=
# 兼容服务的模型 id（OPENAI_BASE_URL 留空时此项仅做 seed 默认）
OPENAI_MODEL=gpt-4o

# ── 搜索 ────────────────────────────────────────────────────────────────────
# 搜索 provider 选择：native=强制 DuckDuckGo / tavily=强制 Tavily / auto=有 key 用 Tavily（默认）
LIF_SEARCH_PROVIDER=auto
# Tavily（LIF_SEARCH_PROVIDER=tavily 或 auto 且此处非空时生效）
TAVILY_API_KEY=
# Jina（可选，web fetch 阅读增强）
JINA_API_KEY=
# Embedding 独立配置（chat provider 不提供 embedding 端点时必须，如 DeepSeek）
# 缺省回退到 OPENAI_API_KEY/OPENAI_BASE_URL/text-embedding-3-small
# 例 1：用 Jina（OpenAI 兼容协议，1024 维）
#   LIF_EMBEDDING_API_KEY=jina_xxx
#   LIF_EMBEDDING_BASE_URL=https://api.jina.ai/v1
#   LIF_EMBEDDING_MODEL=jina-embeddings-v3
# 例 2：用本地 Ollama（免费、内网快；需先 ollama pull bge-m3）
#   LIF_EMBEDDING_API_KEY=ollama
#   LIF_EMBEDDING_BASE_URL=http://localhost:11434/v1
#   LIF_EMBEDDING_MODEL=bge-m3
LIF_EMBEDDING_API_KEY=
LIF_EMBEDDING_BASE_URL=
LIF_EMBEDDING_MODEL=

# ── 运行时 ──────────────────────────────────────────────────────────────────
# HTTP 服务端口
PORT=8787
# 数据目录（task / workflow / config 持久化根）
# 仅作用于内核主服务（pnpm dev）；两个消费 App 默认各自独立（见下）
LIF_DATA_DIR=./data
# NexusOps 独立数据目录（缺省 ./data/nexusops，实现历史会话隔离）
# NEXUS_DATA_DIR=
# AI Content Factory 独立数据目录（缺省 ./data/ai-content-factory）
# AICF_DATA_DIR=

# ── 日志（工具调用 / LLM 调用历史，落盘 verbose 级别）──────────────────────────
# 控制 data/tasks/<taskId>/events.jsonl 与 llm_calls.ndjson 的落盘内容。
# 注意：此开关只影响「是否写日志文件」，不影响 SSE 实时推送与会话框渲染。
#   0 = off（完全不写日志文件，仅走 SSE）
#   1 = basic（只记工具调用元信息 tool_call/tool_result/tool_status + 终态 phase/done/error/extension）
#   2 = full（全部事件，含 Claude Code 风格 narrative text + workflow_node；缺省）
LIF_LOG_VERBOSE=2

# ── 重 IO（podcast 完整视频链，可选）─────────────────────────────────────────
LIF_AICF_REPO_ROOT=
LIF_PYTHON_BIN=python3
LIF_TTS_PYTHON_BIN=python3

# ── 调用点 → 模型（覆盖 registry 绑定，可选；优先级低于 call_site_bindings.json）─
# LIF_PLANNER_MODEL=
# LIF_REWRITE_MODEL=
# LIF_TRANSLATE_MODEL=
# LIF_SEAM_REPAIR_MODEL=
# LIF_TERMINOLOGY_MODEL=
# LIF_IMAGE_PROMPTS_MODEL=
# ReAct Harness 主循环（NexusOps 编排 LLM）
# LIF_NEXUS_AGENT_MODEL=
# 结构化建议产出（NexusOps finalize）
# LIF_NEXUS_ADVISE_MODEL=

# ── NexusOps 应用（运营智能分析，可选）──────────────────────────────────────────
# Obsidian vault 路径（精益五类上下文；留空则不加载 KB provider）
OBSIDIAN_VAULT_PATH=
# MCP server 配置（JSON 数组，见 src/tools/mcp/mcp-client.ts McpServerConfig）
# 例：[{"id":"mes","transport":"http","url":"http://localhost:9000/mcp"}]
#
# catalog 模式（大目录型 server，见 docs/architecture/07-mestar-integration-spec.md）：
# server 暴露"目录检索型"工具（如 mestar.catalog.search + 几千个候选）时，启用 catalog 字段
# 走 McpCatalogCache 预热（分页拉取 + 派生 semanticTags + 分桶缓存），避免全量注册导致 context 爆炸。
# 例：NEXUS_MCP_SERVERS='[{"id":"mestar","transport":"http","url":"http://10.1.9.19:7331/mcp","catalog":{"enabled":true,"pageSize":200,"refreshMs":86400000}}]'
NEXUS_MCP_SERVERS=
# mock 工具统一开关（管理域取证 + mock MCP 动作两类 mock）
# 取值：
#   1 / 未设置 = 全部开启（缺省，向后兼容；所有 domain.* 取证 + mock MCP 动作都走 mock 数据）
#   0 / off    = 全部关闭（域取证 + mock MCP 动作都不注册），LLM 走真实 MCP 三档降级链：
#                  ① nexus_tool_resolver 查 MCP 等价工具 → mcp.<server>.call 执行
#                  ② 找不到等价工具 → 反问用户索取数据
#                  ③ 用户也给不出 → nexus_advise 标注证据缺失，给有限结论
#   actions    = 只关 mock MCP 动作工具（mcp.mes/erp/qms/eam/process.*），保留域取证（= 旧 NEXUS_MOCK_ACTIONS=0）
#   evidence   = 只关域取证（oee.*/quality.*/process.* 等），保留 mock MCP 动作（少见）
# 旧变量 NEXUS_MOCK_ACTIONS=0 仍兼容（内部映射为 actions 档），建议迁移到 NEXUS_MOCK_TOOLS。
NEXUS_MOCK_TOOLS=
# ReAct 最大步数（缺省 15）
NEXUS_MAX_STEPS=15
# ReAct 输入 token 成本上限（缺省不限）
NEXUS_COST_CAP_INPUT=
# NexusOps HTTP 端口（缺省 8788）
NEXUS_PORT=8788
# 是否允许 destructive 工具自动执行（=1 开；缺省禁，仅 HITL 后可）
NEXUS_ALLOW_DESTRUCTIVE=

# ── AI Content Factory 应用（播客内容生产，可选）────────────────────────────────
# HTTP 端口（缺省 8789；pnpm start:aicf 用此端口）
AICF_PORT=8789
# ReAct 最大步数（缺省 20）
PODCAST_MAX_STEPS=20
# KB vault 路径（留空则不加载；pnpm start:aicf 默认初始化到 ./data/aicf-vault）
# 注：与上方 OBSIDIAN_VAULT_PATH 共用同一变量，NexusOps/aicf 各自 boot 时读取

# ── 微信公众号草稿发布（可选，启用 skill.publish_wechat_draft）─────────────────
# 公众号 AppID / AppSecret（已认证订阅号；在公众号后台「设置与开发 → 基本配置」获取）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# 默认封面图本地路径（skill 未传 coverImagePath 时兜底；留空则必须传 thumbMediaId）
WECHAT_DEFAULT_COVER_PATH=
# ⚠️ 调用微信 API 需在公众号后台「设置与开发 → 基本配置 → IP白名单」添加本机出口 IP
# ⚠️ skill 推送前会弹 HITL 确认门，用户批准后才入草稿箱（不会自动群发）
