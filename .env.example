# =============================================================================
# Let-it-Flow 环境变量示例
# 复制为 .env 并填入真实值。.env 已被 .gitignore 排除，勿提交。
# =============================================================================

# ── LLM 密钥（按需配置，对应 registry 的 apiKeyEnv 字段）─────────────────────
# OpenAI 官方 / OpenAI 兼容服务（DeepSeek、通义、Kimi 等）共用此 key
OPENAI_API_KEY=sk-...
# Anthropic Claude（provider=anthropic 时必填，apiKeyEnv=ANTHROPIC_API_KEY）
ANTHROPIC_API_KEY=sk-ant-...
# Azure OpenAI（provider=azure 时必填，apiKeyEnv=AZURE_API_KEY）
AZURE_API_KEY=...
# Ollama 本地无需 key（provider=ollama，baseURL 默认 http://localhost:11434/v1）

# ── OpenAI 兼容服务路由 ─────────────────────────────────────────────────────
# 留空走 OpenAI 官方端点；填 https://api.deepseek.com 等走兼容服务
OPENAI_BASE_URL=
# 兼容服务的模型 id（OPENAI_BASE_URL 留空时此项仅做 seed 默认）
OPENAI_MODEL=gpt-4o

# ── 搜索 ────────────────────────────────────────────────────────────────────
# Tavily（留空走原生 DuckDuckGo）
TAVILY_API_KEY=
# Jina（可选，web fetch 阅读增强）
JINA_API_KEY=

# ── 运行时 ──────────────────────────────────────────────────────────────────
# HTTP 服务端口
PORT=8787
# 数据目录（task / workflow / config 持久化根）
LIF_DATA_DIR=./data

# ── 重 IO（podcast 完整视频链，可选）─────────────────────────────────────────
LIF_AICF_REPO_ROOT=
LIF_PYTHON_BIN=python3
LIF_TTS_PYTHON_BIN=python3

# ── 调用点 → 模型（覆盖 registry 绑定，可选；优先级低于 call_site_bindings.json）─
# LIF_PLANNER_MODEL=
# LIF_REWRITE_MODEL=
# LIF_TRANSLATE_MODEL=
# LIF_SEAM_REPAIR_MODEL=
# LIF_TERMINOLOGY_MODEL=
# LIF_IMAGE_PROMPTS_MODEL=
