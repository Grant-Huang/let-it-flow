{
  "name": "@meso.ai/let-it-flow",
  "version": "0.3.0",
  "description": "Intent-to-DAG Compiler — 开发者友好的、以意图为导向的流式任务编排框架",
  "type": "module",
  "license": "MIT",
  "author": "Grant-Huang",
  "homepage": "https://github.com/Grant-Huang/let-it-flow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Grant-Huang/let-it-flow.git"
  },
  "bugs": {
    "url": "https://github.com/Grant-Huang/let-it-flow/issues"
  },
  "keywords": [
    "workflow",
    "orchestration",
    "dag",
    "llm",
    "agent",
    "intent",
    "streaming",
    "ai-sdk",
    "hono",
    "react-harness"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/server.ts",
    "dev:sdk": "tsx watch src/index.ts",
    "dev:nexus": "tsx watch apps/nexusops/server/index.ts",
    "dev:aicf": "tsx watch apps/ai-content-factory/server/index.ts",
    "dev:nexus:web": "pnpm --filter @let-it-flow/nexusops-web dev",
    "dev:aicf:web": "pnpm --filter @let-it-flow/ai-content-factory-web dev",
    "start:aicf": "tsx scripts/start-aicf.ts",
    "start:aicf:dev": "tsx scripts/start-aicf.ts --dev",
    "lint": "eslint .",
    "full-test": "tsx scripts/full-test.ts",
    "full-test:online": "tsx scripts/full-test.ts --online",
    "scenarios": "tsx tests/scenarios/run.ts",
    "check": "pnpm typecheck && pnpm scenarios",
    "check:full": "pnpm typecheck && pnpm test && pnpm scenarios",
    "smoke": "tsx -e \"import('./src/index.ts').then(m => console.log('import ok', typeof m.LetItFlow))\""
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/azure": "^3.0.74",
    "@ai-sdk/openai": "^2.0.0",
    "@hono/node-server": "^1.13.0",
    "@meso.ai/client": "^0.1.0",
    "@meso.ai/types": "^2.2.0",
    "@meso.ai/ui": "^3.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.0",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "hono": "^4.6.0",
    "jsonpath-plus": "^10.1.0",
    "marked": "^18.0.5",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.0"
  }
}
