# 依赖
node_modules/
.pnpm-store/

# 构建产物
dist/
*.tsbuildinfo
web/dist/
web/node_modules/

# 运行时数据（本地生成，不入库）
data/*
!data/relos-mock/
# syncToolIndex 运行时生成，不入库（boot 时自动重建）
data/relos-mock/tool-index.json
.tmp/
tmp/

# 环境变量与密钥
.env
.env.*
!.env.example

# 日志
*.log
npm-debug.log*
pnpm-debug.log*

# 编辑器
.vscode/
.idea/
.DS_Store

# Python（重 IO provider 子进程可能产生）
__pycache__/
*.pyc
.venv/
venv/

# 参考仓库（嵌套 git，不入库）
reference/

# 测试覆盖率
coverage/
.vitest/

# 全量测试报告（本地生成的运行时产物）
tests/reports/

# IDE 本地配置（不入库，每人自管）
.cursor/

# apps/ —— 消费级参考实现（独立应用，非平台 SDK 交付物，不入库）
# 注意：apps/ 仍由 pnpm-workspace.yaml 注册为本地 workspace，本地开发照常可用
apps/

# Word 文档（非文本，不入库；如需共享走 wiki/网盘）
*.docx
